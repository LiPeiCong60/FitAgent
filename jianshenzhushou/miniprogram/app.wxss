/* ========================================
   AI 健身助手 - 全局样式 (清新黑白配色)
   ======================================== */

/* CSS 变量 */
page {
  --color-primary: #1a1a1a;
  --color-primary-light: #333333;
  --color-primary-dark: #000000;
  --color-accent: #555555;
  --color-accent-light: #888888;
  --color-bg: #f7f8fa;
  --color-bg-card: #ffffff;
  --color-bg-input: #f0f1f3;
  --color-text: #1a1a1a;
  --color-text-secondary: #666666;
  --color-text-muted: #999999;
  --color-success: #1a1a1a;
  --color-warning: #666666;
  --color-danger: #333333;
  --color-border: rgba(0, 0, 0, 0.06);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --shadow-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  --shadow-glow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial,
    sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  min-height: 100vh;
}

/* 通用工具类 */
.container {
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 32rpx;
  background: #1a1a1a;
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.btn-primary {
  background: #1a1a1a;
  color: #ffffff;
  border: none;
  border-radius: var(--radius-xl);
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: var(--shadow-glow);
  transition: all 0.3s ease;
  width: 100%;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.85;
  background: #000000;
}

/* 强调文字 */
.gradient-text {
  color: #1a1a1a;
  -webkit-text-fill-color: #1a1a1a;
}
