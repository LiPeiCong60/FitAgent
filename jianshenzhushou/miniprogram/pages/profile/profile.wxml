<!--pages/profile/profile.wxml-->
<view class="page-container">
  <view class="hero-section">
    <text class="hero-title">完善你的身体档案</text>
    <text class="hero-subtitle">系统会先给出推荐值，你也可以自己调整热量和三大营养素比例。</text>
  </view>

  <view class="card">
    <view class="section-title">基本信息</view>

    <view class="form-item">
      <view class="form-label">
        <text class="form-icon">👤</text>
        <text>性别</text>
      </view>
      <view class="gender-selector">
        <view class="gender-option {{gender === 'male' ? 'active' : ''}}" bindtap="onGenderSelect" data-gender="male">
          <text class="gender-emoji">♂</text>
          <text>男</text>
        </view>
        <view class="gender-option {{gender === 'female' ? 'active' : ''}}" bindtap="onGenderSelect" data-gender="female">
          <text class="gender-emoji">♀</text>
          <text>女</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="form-icon">🎂</text>
        <text>年龄</text>
      </view>
      <view class="input-wrapper">
        <input type="number" placeholder="请输入" placeholder-class="input-placeholder" value="{{age}}" bindinput="onAgeInput" />
        <text class="input-unit">岁</text>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="form-icon">📏</text>
        <text>身高</text>
      </view>
      <view class="input-wrapper">
        <input type="digit" placeholder="请输入" placeholder-class="input-placeholder" value="{{height}}" bindinput="onHeightInput" />
        <text class="input-unit">cm</text>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="form-icon">⚖️</text>
        <text>体重</text>
      </view>
      <view class="input-wrapper">
        <input type="digit" placeholder="请输入" placeholder-class="input-placeholder" value="{{weight}}" bindinput="onWeightInput" />
        <text class="input-unit">kg</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">健身目标</view>

    <view class="goal-selector">
      <view class="goal-option {{goal === 'lose' ? 'active' : ''}}" bindtap="onGoalSelect" data-goal="lose">
        <text class="goal-emoji">🔥</text>
        <text class="goal-text">减脂</text>
        <text class="goal-desc">-500 kcal</text>
      </view>
      <view class="goal-option {{goal === 'gain' ? 'active' : ''}}" bindtap="onGoalSelect" data-goal="gain">
        <text class="goal-emoji">💪</text>
        <text class="goal-text">增肌</text>
        <text class="goal-desc">+300 kcal</text>
      </view>
      <view class="goal-option {{goal === 'maintain' ? 'active' : ''}}" bindtap="onGoalSelect" data-goal="maintain">
        <text class="goal-emoji">⚖</text>
        <text class="goal-text">维持</text>
        <text class="goal-desc">平衡</text>
      </view>
    </view>

    <view class="divider"></view>

    <view class="section-title">运动频率</view>

    <view class="activity-list">
      <view class="activity-option {{activityLevel === 'sedentary' ? 'active' : ''}}" bindtap="onActivitySelect" data-level="sedentary">
        <view class="activity-info">
          <text class="activity-name">久坐少动</text>
          <text class="activity-desc">很少或没有运动</text>
        </view>
        <text class="activity-factor">x1.2</text>
      </view>
      <view class="activity-option {{activityLevel === 'light' ? 'active' : ''}}" bindtap="onActivitySelect" data-level="light">
        <view class="activity-info">
          <text class="activity-name">轻度运动</text>
          <text class="activity-desc">每周 1-3 天</text>
        </view>
        <text class="activity-factor">x1.375</text>
      </view>
      <view class="activity-option {{activityLevel === 'moderate' ? 'active' : ''}}" bindtap="onActivitySelect" data-level="moderate">
        <view class="activity-info">
          <text class="activity-name">中度运动</text>
          <text class="activity-desc">每周 3-5 天</text>
        </view>
        <text class="activity-factor">x1.55</text>
      </view>
      <view class="activity-option {{activityLevel === 'active' ? 'active' : ''}}" bindtap="onActivitySelect" data-level="active">
        <view class="activity-info">
          <text class="activity-name">高强度运动</text>
          <text class="activity-desc">每周 6-7 天</text>
        </view>
        <text class="activity-factor">x1.725</text>
      </view>
      <view class="activity-option {{activityLevel === 'extreme' ? 'active' : ''}}" bindtap="onActivitySelect" data-level="extreme">
        <view class="activity-info">
          <text class="activity-name">专业训练</text>
          <text class="activity-desc">高强度训练或体力劳动</text>
        </view>
        <text class="activity-factor">x1.9</text>
      </view>
    </view>
  </view>

  <view class="card result-card" wx:if="{{showResult}}">
    <view class="section-title">你的目标设置</view>
    <view class="result-grid">
      <view class="result-item">
        <text class="result-label">BMR</text>
        <text class="result-value">{{bmr}}</text>
        <text class="result-hint">基础代谢 kcal</text>
      </view>
      <view class="result-divider"></view>
      <view class="result-item">
        <text class="result-label">TDEE</text>
        <text class="result-value">{{tdee}}</text>
        <text class="result-hint">每日消耗 kcal</text>
      </view>
      <view class="result-divider"></view>
      <view class="result-item highlight">
        <text class="result-label">推荐热量</text>
        <text class="result-value">{{recommendedCalories}}</text>
        <text class="result-hint">系统推荐 kcal</text>
      </view>
    </view>

    <view class="custom-section">
      <view class="form-item compact">
        <view class="form-label">
          <text class="form-icon">🍽</text>
          <text>每日热量</text>
        </view>
        <view class="input-wrapper">
          <input type="number" placeholder="请输入目标热量" placeholder-class="input-placeholder" value="{{dailyCalories}}" bindinput="onDailyCaloriesInput" />
          <text class="input-unit">kcal</text>
        </view>
      </view>
      <text class="section-tip">你可以直接修改成自己想吃的热量目标。</text>

      <view class="macro-editor">
        <view class="macro-editor-header">
          <text class="section-title">三大营养素比例</text>
          <text class="macro-sum">总和需为 100%</text>
        </view>
        <view class="macro-input-grid">
          <view class="macro-input-item">
            <text class="macro-input-label">碳水</text>
            <view class="input-wrapper macro-input-wrapper">
              <input type="digit" value="{{carbsRatio}}" bindinput="onCarbsRatioInput" />
              <text class="input-unit">%</text>
            </view>
          </view>
          <view class="macro-input-item">
            <text class="macro-input-label">蛋白质</text>
            <view class="input-wrapper macro-input-wrapper">
              <input type="digit" value="{{proteinRatio}}" bindinput="onProteinRatioInput" />
              <text class="input-unit">%</text>
            </view>
          </view>
          <view class="macro-input-item">
            <text class="macro-input-label">脂肪</text>
            <view class="input-wrapper macro-input-wrapper">
              <input type="digit" value="{{fatRatio}}" bindinput="onFatRatioInput" />
              <text class="input-unit">%</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="btn-area">
    <button class="btn-primary" bindtap="onSave" loading="{{saving}}">
      {{saving ? '保存中...' : '保存并生成计划'}}
    </button>
  </view>
</view>
