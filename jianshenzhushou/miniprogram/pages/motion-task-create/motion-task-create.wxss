.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.card {
  margin-top: 32rpx;
  padding: 40rpx 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #666666;
}

.btn {
  margin-top: 32rpx;
}
