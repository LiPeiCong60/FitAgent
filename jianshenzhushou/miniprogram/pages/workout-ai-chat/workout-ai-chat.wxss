/* pages/workout-ai-chat/workout-ai-chat.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

.chat-scroll {
  flex: 1;
  padding: 0 24rpx;
}

.chat-list {
  padding: 24rpx 0 32rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.msg-user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.msg-user .msg-avatar {
  background: #1a1a1a;
  color: #ffffff;
}

.msg-bubble {
  max-width: 560rpx;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  margin: 0 16rpx;
  line-height: 1.6;
}

.msg-ai .msg-bubble {
  background: #ffffff;
  border: 1rpx solid var(--color-border);
  border-top-left-radius: 4rpx;
}

.msg-user .msg-bubble {
  background: #1a1a1a;
  color: #ffffff;
  border-top-right-radius: 4rpx;
}

.msg-text {
  font-size: 28rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.msg-user .msg-text {
  color: #ffffff;
}

.typing {
  display: flex;
  gap: 8rpx;
  padding: 20rpx 28rpx;
}

.typing-dot {
  font-size: 24rpx;
  color: var(--color-text-muted);
  animation: typing-blink 1.4s infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing-blink {
  0%, 60%, 100% { opacity: 0.2; }
  30% { opacity: 1; }
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid var(--color-border);
  gap: 16rpx;
}

.chat-input {
  flex: 1;
  background: var(--color-bg-input);
  border-radius: var(--radius-xl);
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.chat-placeholder {
  color: var(--color-text-muted);
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}

.send-btn.active {
  background: #1a1a1a;
}

.send-icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 700;
}
