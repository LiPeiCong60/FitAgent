<!--pages/diet-add/diet-add.wxml-->
<view class="page-container">
  <view class="card camera-card">
    <view class="camera-area" bindtap="takePhoto">
      <view class="camera-content" wx:if="{{!photoUrl}}">
        <text class="camera-icon">📷</text>
        <text class="camera-text">拍照识别食物</text>
        <text class="camera-hint">AI 自动识别食物和热量</text>
      </view>
      <view class="camera-preview" wx:else>
        <image src="{{photoUrl}}" mode="aspectFill" class="photo-img" />
      </view>
    </view>

    <view class="recognize-result" wx:if="{{recognizeResult}}">
      <view class="recognize-loading" wx:if="{{recognizing}}">
        <text>识别中...</text>
      </view>
      <view class="recognize-info" wx:else>
        <text class="recognize-name">{{recognizeResult.name}}</text>
        <text class="recognize-detail">约 {{recognizeResult.calories}} kcal · {{recognizeResult.grams}}g</text>
        <view class="recognize-actions">
          <button class="btn-use" size="mini" bindtap="useRecognizeResult">使用结果</button>
          <button class="btn-retry" size="mini" bindtap="retakePhoto">重新拍照</button>
        </view>
      </view>
    </view>

    <view class="recognize-loading" wx:if="{{recognizing && !recognizeResult}}">
      <text>识别中...</text>
    </view>
  </view>

  <view class="or-divider">
    <view class="or-line"></view>
    <text class="or-text">或手动添加</text>
    <view class="or-line"></view>
  </view>

  <view class="custom-entry" bindtap="openCustomFoodModal">
    <view class="custom-entry-left">
      <text class="custom-entry-title">自定义食物</text>
      <text class="custom-entry-desc">手动填写食物名称、热量、重量和三大营养素</text>
    </view>
    <text class="custom-entry-arrow">→</text>
  </view>

  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      placeholder="搜索食物，如鸡胸肉、米饭"
      placeholder-class="search-placeholder"
      value="{{keyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
    />
    <text class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
  </view>

  <view class="food-result-list">
    <view
      class="food-result-item"
      wx:for="{{filteredFoods}}"
      wx:key="id"
      bindtap="selectFood"
      data-food="{{item}}"
      hover-class="food-result-hover"
    >
      <view class="food-result-info">
        <text class="food-result-name">{{item.name}}</text>
        <text class="food-result-unit">{{item.unit}}</text>
      </view>
      <view class="food-result-right">
        <text class="food-result-cal">{{item.calories}} kcal</text>
        <text class="food-result-per">/100g</text>
      </view>
    </view>

    <view class="no-result" wx:if="{{filteredFoods.length === 0 && keyword}}">
      <text>没有找到“{{keyword}}”，可以使用上方自定义食物</text>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="preventClose">
      <block wx:if="{{modalMode === 'preset'}}">
        <text class="modal-title">{{selectedFood.name}}</text>
        <text class="modal-hint">参考 {{selectedFood.unit}}</text>

        <view class="modal-input-row">
          <input
            class="modal-input"
            type="digit"
            placeholder="输入克数"
            value="{{inputGrams}}"
            bindinput="onGramsInput"
            focus="{{showModal}}"
          />
          <text class="modal-unit">克</text>
        </view>

        <view class="quick-grams">
          <text class="quick-btn" bindtap="setQuickGrams" data-grams="50">50g</text>
          <text class="quick-btn" bindtap="setQuickGrams" data-grams="100">100g</text>
          <text class="quick-btn" bindtap="setQuickGrams" data-grams="150">150g</text>
          <text class="quick-btn" bindtap="setQuickGrams" data-grams="200">200g</text>
          <text class="quick-btn" bindtap="setQuickGrams" data-grams="300">300g</text>
        </view>

        <view class="modal-preview" wx:if="{{inputGrams}}">
          <view class="preview-row">
            <text class="preview-label">热量</text>
            <text class="preview-value">{{previewCalories}} kcal</text>
          </view>
          <view class="preview-row">
            <text class="preview-label">蛋白质</text>
            <text class="preview-value">{{previewProtein}}g</text>
          </view>
          <view class="preview-row">
            <text class="preview-label">脂肪</text>
            <text class="preview-value">{{previewFat}}g</text>
          </view>
          <view class="preview-row">
            <text class="preview-label">碳水</text>
            <text class="preview-value">{{previewCarbs}}g</text>
          </view>
        </view>
      </block>

      <block wx:elif="{{modalMode === 'custom'}}">
        <text class="modal-title">自定义食物</text>
        <text class="modal-hint">填写本次实际摄入的数据</text>

        <view class="custom-form">
          <view class="custom-field">
            <text class="custom-label">食物名称</text>
            <input class="custom-input" placeholder="例如 自制牛肉饭" value="{{customFoodName}}" bindinput="onCustomNameInput" />
          </view>

          <view class="custom-grid">
            <view class="custom-field">
              <text class="custom-label">热量 kcal</text>
              <input class="custom-input" type="digit" placeholder="例如 520" value="{{customCalories}}" bindinput="onCustomCaloriesInput" />
            </view>
            <view class="custom-field">
              <text class="custom-label">重量 g</text>
              <input class="custom-input" type="digit" placeholder="例如 350" value="{{customGrams}}" bindinput="onCustomGramsInput" />
            </view>
          </view>

          <view class="custom-grid nutrition-grid">
            <view class="custom-field">
              <text class="custom-label">碳水 g</text>
              <input class="custom-input" type="digit" placeholder="0" value="{{customCarbs}}" bindinput="onCustomCarbsInput" />
            </view>
            <view class="custom-field">
              <text class="custom-label">蛋白质 g</text>
              <input class="custom-input" type="digit" placeholder="0" value="{{customProtein}}" bindinput="onCustomProteinInput" />
            </view>
            <view class="custom-field">
              <text class="custom-label">脂肪 g</text>
              <input class="custom-input" type="digit" placeholder="0" value="{{customFat}}" bindinput="onCustomFatInput" />
            </view>
          </view>
        </view>
      </block>

      <button class="btn-primary modal-confirm" bindtap="confirmAdd">确认添加</button>
    </view>
  </view>
</view>
